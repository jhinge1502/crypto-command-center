{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "npm run build --workspace @assignment4/worker"
  },
  "deploy": {
    "startCommand": "npm run start --workspace @assignment4/worker",
    "restartPolicyType": "ALWAYS",
    "restartPolicyMaxRetries": 10
  }
}
